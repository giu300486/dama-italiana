root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java}]
indent_style = space
indent_size = 2
max_line_length = 100

[*.{xml,yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,md}]
indent_style = space
indent_size = 2

[*.properties]
charset = utf-8
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf
