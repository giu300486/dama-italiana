<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.damaitaliana.client.ui.rules.RulesController"
            styleClass="screen-root"
            prefWidth="1024" prefHeight="768">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <top>
        <HBox spacing="16" alignment="CENTER_LEFT">
            <padding>
                <Insets top="0" right="0" bottom="16" left="0"/>
            </padding>
            <Label fx:id="titleLabel" styleClass="label-display, label-display-md"/>
            <Region HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="backButton" onAction="#onBack" styleClass="button-secondary"/>
        </HBox>
    </top>

    <center>
        <!-- F4.5 Task 4.5.6: outer StackPane centers the SplitPane horizontally; SplitPane caps
             at maxWidth=1200 so the rules content doesn't stretch beyond a readable width on
             ultrawide / 4K (audit Task 4.5.2 confirmed huge empty cream area on the right pane
             at 3440×1440). -->
        <StackPane fx:id="rulesCenter">
            <SplitPane dividerPositions="0.28" maxWidth="1200">
                <items>
                    <ListView fx:id="sectionsList"/>
                    <ScrollPane fx:id="contentScroll" fitToWidth="true" styleClass="card-elevated">
                        <content>
                            <VBox fx:id="contentBox" spacing="16">
                                <padding>
                                    <Insets top="16" right="16" bottom="16" left="16"/>
                                </padding>
                            </VBox>
                        </content>
                    </ScrollPane>
                </items>
            </SplitPane>
        </StackPane>
    </center>
</BorderPane>
