<?xml version="1.0" encoding="UTF-8"?>

<?import com.damaitaliana.client.ui.board.BoardRenderer?>
<?import com.damaitaliana.client.ui.board.MoveHistoryView?>
<?import com.damaitaliana.client.ui.board.StatusPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.damaitaliana.client.ui.board.BoardViewController">
    <top>
        <VBox>
            <MenuBar fx:id="menuBar">
                <Menu fx:id="gameMenu">
                    <items>
                        <MenuItem fx:id="undoMenuItem" onAction="#onUndo"/>
                        <MenuItem fx:id="redoMenuItem" onAction="#onRedo"/>
                        <MenuItem fx:id="saveMenuItem" onAction="#onSaveAs"/>
                        <MenuItem fx:id="loadMenuItem" onAction="#onLoad"/>
                        <MenuItem fx:id="rulesMenuItem" onAction="#onShowRules"/>
                        <MenuItem fx:id="terminateMenuItem" onAction="#onTerminate"/>
                    </items>
                </Menu>
            </MenuBar>
            <HBox spacing="16" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="16" right="16" bottom="0" left="16"/>
                </padding>
                <Label fx:id="gameTitleLabel" styleClass="label-title"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <BorderPane>
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <center>
                <StackPane styleClass="board-frame">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>
                    <!-- F4.5 Task 4.5.4: minWidth/minHeight removed; the renderer now scales
                         freely between 0 and the available area. The Stage min size (1024×720
                         enforced by PrimaryStageInitializer) still guarantees a usable cellSize
                         (~63px at floor) once side panel and chrome are subtracted. -->
                    <BoardRenderer fx:id="boardRenderer"/>
                </StackPane>
            </center>
            <right>
                <!-- F4.5 Task 4.5.5: side panel responsive width.
                     pref=320 / min=240 / max=400 (PLAN-fase-4.5 §10.6 token spacing).
                     Auto-hide for viewport < 1024 is unreachable in normal operation
                     because PrimaryStageInitializer enforces Stage min 1024×720, so
                     the panel is always visible. MoveHistoryView keeps VBox.vgrow=ALWAYS
                     so the history list expands to fill the vertical space between the
                     status pane and the back button. -->
                <VBox fx:id="sidePanel" spacing="12"
                      prefWidth="320" minWidth="240" maxWidth="400"
                      styleClass="card-elevated">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <StatusPane fx:id="statusPane"/>
                    <MoveHistoryView fx:id="moveHistoryView" VBox.vgrow="ALWAYS"/>
                    <Button fx:id="backButton" onAction="#onBack" styleClass="button-secondary"/>
                </VBox>
            </right>
        </BorderPane>
    </center>
</BorderPane>
