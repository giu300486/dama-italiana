# Dama Italiana — variabili d'ambiente di sviluppo
# Copia in .env (escluso da git) e adatta i valori se necessario.
# I default funzionano per dev locale e NON sono adatti a produzione.

# --- MySQL (Docker Compose) ---
MYSQL_DATABASE=dama_italiana
MYSQL_USER=dama
MYSQL_PASSWORD=dama
MYSQL_ROOT_PASSWORD=root
MYSQL_HOST_PORT=3307

# --- Adminer ---
ADMINER_HOST_PORT=8081

# --- Spring Boot server (lette da application.yml) ---
DB_URL=jdbc:mysql://localhost:3307/dama_italiana
DB_USERNAME=dama
DB_PASSWORD=dama
SERVER_PORT=8080

# --- JWT (placeholder; da rigenerare con valore robusto in Fase 5) ---
# JWT_SECRET=replace-me-with-a-256-bit-secret
